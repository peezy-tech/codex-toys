{
	"name": "@codex-toys/bridge",
	"version": "0.140.14",
	"private": true,
	"description": "Native Codex app-server, auth, thread, memory, and state bridge primitives.",
	"type": "module",
	"license": "Apache-2.0",
	"sideEffects": false,
	"types": "./dist/index.d.ts",
	"files": ["dist", "README.md"],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./auth": {
			"types": "./dist/auth.d.ts",
			"import": "./dist/auth.js"
		},
		"./json": {
			"types": "./dist/json.d.ts",
			"import": "./dist/json.js"
		},
		"./memories": {
			"types": "./dist/memories.d.ts",
			"import": "./dist/memories.js"
		},
		"./threads": {
			"types": "./dist/threads.d.ts",
			"import": "./dist/threads.js"
		},
		"./rpc": {
			"types": "./dist/app-server/rpc.d.ts",
			"import": "./dist/app-server/rpc.js"
		},
		"./generated": {
			"types": "./dist/app-server/generated/index.d.ts",
			"import": "./dist/app-server/generated/index.js"
		},
		"./generated/*": {
			"types": "./dist/app-server/generated/*.d.ts",
			"import": "./dist/app-server/generated/*.js"
		},
		"./app-server/*": {
			"types": "./dist/app-server/*.d.ts",
			"import": "./dist/app-server/*.js"
		}
	},
	"engines": {
		"node": ">=24.0.0 <25"
	},
	"scripts": {
		"build": "vp run clean && tsc -p tsconfig.build.json",
		"check:types": "tsc --noEmit",
		"clean": "rm -rf dist",
		"prepack": "vp run build",
		"release:check": "vp run check:types && vp run build && vp run pack:dry-run",
		"pack:dry-run": "tsx ../../scripts/package-pack-dry-run.ts"
	},
	"devDependencies": {
		"@types/node": "catalog:",
		"typescript": "catalog:"
	}
}
