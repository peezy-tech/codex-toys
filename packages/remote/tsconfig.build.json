{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"declaration": true,
		"declarationMap": true,
		"emitDeclarationOnly": false,
		"noEmit": false,
		"outDir": "dist",
		"rootDir": "src",
		"sourceMap": true,
		"rewriteRelativeImportExtensions": true,
		"paths": {}
	},
	"include": ["src/**/*.ts"],
	"exclude": ["dist"]
}
