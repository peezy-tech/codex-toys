{
	"name": "@codex-toys/feed",
	"version": "0.140.7",
	"private": true,
	"description": "Durable external feed polling, RSS normalization, checkpoints, and collection cursors.",
	"type": "module",
	"license": "Apache-2.0",
	"sideEffects": false,
	"types": "./dist/index.d.ts",
	"files": ["dist", "README.md"],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"engines": {
		"node": ">=24.0.0 <25"
	},
	"scripts": {
		"build": "vp run clean && tsc -p tsconfig.build.json",
		"check:types": "tsc --noEmit",
		"clean": "rm -rf dist",
		"prepack": "vp run build",
		"release:check": "vp run check:types && vp run build && vp run pack:dry-run",
		"pack:dry-run": "tsx ../../scripts/package-pack-dry-run.ts"
	},
	"dependencies": {
		"@codex-toys/toybox": "workspace:*",
		"smol-toml": "catalog:"
	},
	"devDependencies": {
		"@types/node": "catalog:",
		"typescript": "catalog:"
	}
}
