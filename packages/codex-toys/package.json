{
	"name": "codex-toys",
	"version": "0.140.15",
	"description": "Codex CLI and umbrella runtime export for bridge, runtime, feed, workbench, actions, and kits.",
	"type": "module",
	"license": "Apache-2.0",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/peezy-tech/codex-toys.git",
		"directory": "packages/codex-toys"
	},
	"keywords": [
		"codex",
		"codex-app-server",
		"json-rpc",
		"workflow"
	],
	"sideEffects": false,
	"types": "./dist/index.d.ts",
	"bin": {
		"codex-toys": "dist/cli/index.js"
	},
	"files": [
		"dist",
		"docs",
		"README.md"
	],
	"publishConfig": {
		"access": "public"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./actions": {
			"types": "./dist/actions.d.ts",
			"import": "./dist/actions.js"
		},
		"./bridge": {
			"types": "./dist/bridge/index.d.ts",
			"import": "./dist/bridge/index.js"
		},
		"./bridge/auth": {
			"types": "./dist/bridge/auth.d.ts",
			"import": "./dist/bridge/auth.js"
		},
		"./bridge/generated": {
			"types": "./dist/bridge/generated.d.ts",
			"import": "./dist/bridge/generated.js"
		},
		"./bridge/json": {
			"types": "./dist/bridge/json.d.ts",
			"import": "./dist/bridge/json.js"
		},
		"./bridge/memories": {
			"types": "./dist/bridge/memories.d.ts",
			"import": "./dist/bridge/memories.js"
		},
		"./bridge/rpc": {
			"types": "./dist/bridge/rpc.d.ts",
			"import": "./dist/bridge/rpc.js"
		},
		"./bridge/threads": {
			"types": "./dist/bridge/threads.d.ts",
			"import": "./dist/bridge/threads.js"
		},
		"./feed": {
			"types": "./dist/feed.d.ts",
			"import": "./dist/feed.js"
		},
		"./kits": {
			"types": "./dist/kits.d.ts",
			"import": "./dist/kits.js"
		},
		"./runtime": {
			"types": "./dist/runtime.d.ts",
			"import": "./dist/runtime.js"
		},
		"./workbench": {
			"types": "./dist/workbench.d.ts",
			"import": "./dist/workbench.js"
		}
	},
	"bundledDependencies": [
		"smol-toml",
		"tsx",
		"esbuild",
		"@esbuild/linux-x64"
	],
	"engines": {
		"node": ">=24.0.0 <25"
	},
	"scripts": {
		"build": "vp run clean && tsc -p tsconfig.build.json && tsx scripts/assemble-public-dist.ts && chmod 755 dist/cli/index.js",
		"check:types": "tsc --noEmit",
		"clean": "rm -rf dist",
		"pack:dry-run": "tsx scripts/pack-dry-run.ts",
		"prepack": "vp run build",
		"release:check": "vp run test && vp run check:types && vp run build && vp run smoke:exports && vp run smoke:bins && vp run pack:dry-run",
		"smoke:bins": "tsx scripts/smoke-bins.ts",
		"smoke:exports": "tsx scripts/smoke-exports.ts",
		"test": "vp test run --root ../.. packages/codex-toys/test"
	},
	"devDependencies": {
		"@types/node": "catalog:",
		"typescript": "catalog:"
	},
	"dependencies": {
		"@codex-toys/actions": "workspace:*",
		"@codex-toys/bridge": "workspace:*",
		"@codex-toys/feed": "workspace:*",
		"@codex-toys/kits": "workspace:*",
		"@codex-toys/proxy": "workspace:*",
		"@codex-toys/remote": "workspace:*",
		"@codex-toys/toybox": "workspace:*",
		"@codex-toys/workbench": "workspace:*",
		"esbuild": "catalog:",
		"smol-toml": "catalog:",
		"tsx": "catalog:"
	},
	"optionalDependencies": {
		"@esbuild/linux-x64": "0.28.0"
	}
}
