{
	"name": "@peezy.tech/codex-flows",
	"version": "0.132.8",
	"description": "Codex app-server clients, turn automation, workspace backend helpers, and runnable local backend bins.",
	"type": "module",
	"license": "Apache-2.0",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/peezy-tech/codex-flows.git",
		"directory": "packages/codex-client"
	},
	"keywords": [
		"codex",
		"codex-app-server",
		"json-rpc",
		"automation"
	],
	"sideEffects": false,
	"types": "./dist/index.d.ts",
	"bin": {
		"codex-flows": "dist/cli/index.js",
		"codex-app": "dist/bin/codex-app.js",
		"codex-workspace-backend-local": "dist/bin/codex-workspace-backend-local.js"
	},
	"files": [
		"dist",
		"README.md"
	],
	"publishConfig": {
		"access": "public"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"require": "./dist/index.js",
			"import": "./dist/index.js"
		},
		"./browser": {
			"types": "./dist/browser.d.ts",
			"require": "./dist/browser.js",
			"import": "./dist/browser.js"
		},
		"./auth": {
			"types": "./dist/auth.d.ts",
			"require": "./dist/auth.js",
			"import": "./dist/auth.js"
		},
		"./actions": {
			"types": "./dist/actions.d.ts",
			"require": "./dist/actions.js",
			"import": "./dist/actions.js"
		},
		"./memories": {
			"types": "./dist/memories.d.ts",
			"require": "./dist/memories.js",
			"import": "./dist/memories.js"
		},
		"./workbench": {
			"types": "./dist/workbench.d.ts",
			"require": "./dist/workbench.js",
			"import": "./dist/workbench.js"
		},
		"./threads": {
			"types": "./dist/threads.d.ts",
			"require": "./dist/threads.js",
			"import": "./dist/threads.js"
		},
		"./workspace-backend": {
			"types": "./dist/workspace-backend/index.d.ts",
			"require": "./dist/workspace-backend/index.js",
			"import": "./dist/workspace-backend/index.js"
		},
		"./rpc": {
			"types": "./dist/app-server/rpc.d.ts",
			"require": "./dist/app-server/rpc.js",
			"import": "./dist/app-server/rpc.js"
		},
		"./generated": {
			"types": "./dist/app-server/generated/index.d.ts",
			"require": "./dist/app-server/generated/index.js",
			"import": "./dist/app-server/generated/index.js"
		},
		"./generated/*": {
			"types": "./dist/app-server/generated/*.d.ts",
			"require": "./dist/app-server/generated/*.js",
			"import": "./dist/app-server/generated/*.js"
		}
	},
	"engines": {
		"node": ">=24.0.0 <25"
	},
	"scripts": {
		"build": "vp run clean && tsc -p tsconfig.build.json && vp run build:bins",
		"build:bins": "tsx scripts/build-bins.ts",
		"check:types": "tsc --noEmit",
		"clean": "rm -rf dist",
		"pack:dry-run": "tsx scripts/pack-dry-run.ts",
		"prepack": "vp run build",
		"release:check": "vp run test && vp run check:types && vp run build && vp run smoke:exports && vp run smoke:bins && vp run pack:dry-run",
		"smoke:bins": "tsx scripts/smoke-bins.ts",
		"smoke:exports": "tsx scripts/smoke-exports.ts",
		"test": "vp test run --root ../.. packages/codex-client/test"
	},
	"devDependencies": {
		"@types/node": "catalog:",
		"@types/ws": "catalog:",
		"typescript": "catalog:"
	},
	"dependencies": {
		"smol-toml": "catalog:",
		"tsx": "catalog:",
		"ws": "catalog:"
	}
}
