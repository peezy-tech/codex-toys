{
	"name": "@codex-toys/proxy",
	"version": "0.140.6",
	"private": true,
	"description": "HTTP and Vite bridge for local or SSH-backed Codex toyboxes.",
	"type": "module",
	"license": "Apache-2.0",
	"sideEffects": false,
	"types": "./dist/index.d.ts",
	"bin": {
		"codex-toys-proxy": "dist/bin/codex-toys-proxy.js"
	},
	"files": ["dist", "README.md"],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./browser": {
			"types": "./dist/browser.d.ts",
			"import": "./dist/browser.js"
		},
		"./vite": {
			"types": "./dist/vite.d.ts",
			"import": "./dist/vite.js"
		}
	},
	"engines": {
		"node": ">=24.0.0 <25"
	},
	"scripts": {
		"build": "vp run clean && tsc -p tsconfig.build.json && vp run build:bins",
		"build:bins": "tsx scripts/build-bins.ts",
		"check:types": "tsc --noEmit",
		"clean": "rm -rf dist",
		"prepack": "vp run build",
		"release:check": "vp run check:types && vp run build && vp run pack:dry-run",
		"pack:dry-run": "tsx ../../scripts/package-pack-dry-run.ts"
	},
	"dependencies": {
		"@codex-toys/bridge": "workspace:*",
		"@codex-toys/remote": "workspace:*",
		"@codex-toys/toybox": "workspace:*",
		"@codex-toys/workbench": "workspace:*"
	},
	"devDependencies": {
		"@types/node": "catalog:",
		"typescript": "catalog:",
		"vite": "catalog:"
	}
}
